# Hawaii DOE App — environment template
# Copy this file to `.env` and fill in the real values from the
# Supabase dashboard (Project Settings → API).
#
# IMPORTANT: never commit `.env`. Only the anon key belongs in the
# client bundle. The service_role key must NEVER be added here — it
# is only used by Edge Functions and admin tooling.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
